class Point
{
    float x;
    float y;

    float extent()
    {
        return max(this.x, this.y);
    }
}

class Sphere
{
    float radius;

    float extent(Point p)
    {
        float pe1 = p.extent();
        float pe2 = p.extent();
        return pe1 + pe2 + this.radius;
    }
}

Point p = {1.0, 2.0};
Sphere s = {3.0};
s.extent(p);
