<?xml version="1.0"?>
<materialx version="1.39">
  <nodedef name="ND_foo" node="foo">
    <input name="x" type="float" />
    <output name="nonlocal_out__y" type="float" />
    <output name="out" type="float" />
  </nodedef>
  <nodegraph name="NG_foo" nodedef="ND_foo">
    <output name="nonlocal_out__y" type="float" interfacename="x" />
    <multiply name="node1" type="float">
      <input name="in1" type="float" interfacename="x" />
      <input name="in2" type="float" interfacename="x" />
    </multiply>
    <output name="out" type="float" nodename="node1" />
  </nodegraph>
  <foo name="node1" type="multioutput">
    <input name="x" type="float" value="3" />
    <output name="nonlocal_out__y" type="float" />
    <output name="out" type="float" />
  </foo>
  <foo name="node2" type="multioutput">
    <input name="x" type="float" value="5" />
    <output name="nonlocal_out__y" type="float" />
    <output name="out" type="float" />
  </foo>
  <add name="end" type="float">
    <input name="in1" type="float" output="nonlocal_out__y" nodename="node1" />
    <input name="in2" type="float" output="nonlocal_out__y" nodename="node2" />
  </add>
</materialx>
